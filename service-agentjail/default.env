SERVICE_NAME=agentjail
VERSION=local
ENVIRONMENT=dev
LOG_LEVEL=DEBUG

# Server
AGENTJAIL_HOST=0.0.0.0
AGENTJAIL_PORT=8000

# Sandbox
AGENTJAIL_SANDBOX_BASE_DIR=/var/lib/agentjail/sandboxes
AGENTJAIL_STATE_FILE=/var/lib/agentjail/state.json
AGENTJAIL_RUNNER=nsjail
AGENTJAIL_NSJAIL_BIN=nsjail

# Resources (read-only files injected into every sandbox at /resources)
# AGENTJAIL_RESOURCES_DIR=/var/lib/agentjail/resources

# Defaults
AGENTJAIL_DEFAULT_TIME_LIMIT=30
AGENTJAIL_DEFAULT_MEMORY_LIMIT=256
AGENTJAIL_DEFAULT_PIDS_LIMIT=64
